# Copy this file to .env and fill in your values

PORT=3001

# --- Gmail OAuth2 ---
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:3001/auth/gmail/callback

# --- Yahoo ---
# Option A: App Password (easiest — generate at https://login.yahoo.com/account/security)
# Option B: Yahoo OAuth (same flow as Gmail but via Yahoo Developer Console)
YAHOO_APP_PASSWORD=your_yahoo_app_password_here

# --- Database ---
DB_PATH=./email-cleaner.db
